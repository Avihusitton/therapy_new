#!/bin/sh

branch=$(git symbolic-ref --short HEAD)
if [ "$branch" = "main" ]; then
  echo "אסור commit על main! עבור ל-stage"
  exit 1
fi

if [ -t 1 ]; then
  printf "קראת את ARCHITECTURE.md? (y/n): "
  read answer </dev/tty
  if [ "$answer" != "y" ]; then
    echo "Commit בוטל."
    exit 1
  fi
fi

npx lint-staged
